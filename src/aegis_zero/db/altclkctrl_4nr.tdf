FUNCTION cycloneive_clkctrl (clkselect[1..0], ena, inclk[3..0])
WITH ( clock_type, ena_register_mode)
RETURNS ( outclk);

--synthesis_resources = clkctrl 1 reg 2 
OPTIONS ALTERA_INTERNAL_OPTION = "{-to ena_reg} POWER_UP_LEVEL=HIGH;{-to select_reg} POWER_UP_LEVEL=LOW";

SUBDESIGN altclkctrl_4nr
( 
	clkselect[0..0]	:	input;
	inclk[1..0]	:	input;
	outclk	:	output;
) 
VARIABLE 
	ena_reg : dffe
		WITH (
			power_up = "high"
		);
	select_reg[0..0] : dffe
		WITH (
			power_up = "low"
		);
	clkctrl1 : cycloneive_clkctrl
		WITH (
			clock_type = "AUTO"
		);
	clkselect_wire[1..0]	: WIRE;
	ena	: NODE;
	inclk_wire[3..0]	: WIRE;
	select_enable_wire[0..0]	: WIRE;

BEGIN 
	ena_reg.clk = (! clkctrl1.outclk);
	ena_reg.d = (ena & (! select_enable_wire[0..0]));
	select_reg[].clk = (! clkctrl1.outclk);
	select_reg[].d = clkselect_wire[0..0];
	select_reg[].ena = (! ena_reg.q);
	clkctrl1.clkselect[] = ( B"0", select_reg[].q);
	clkctrl1.ena = B"1";
	clkctrl1.inclk[] = inclk_wire[];
	clkselect_wire[] = ( B"0", clkselect[]);
	ena = VCC;
	inclk_wire[] = ( B"00", inclk[]);
	outclk = (clkctrl1.outclk & ena_reg.q);
	select_enable_wire[] = ( (clkselect_wire[0..0] $ select_reg[0..0].q));
END;
--VALID FILE
