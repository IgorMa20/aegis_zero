--altclkctrl CBX_DECLARE_ALL_CONNECTED_PORTS="OFF" CLOCK_TYPE="AUTO" DEVICE_FAMILY="Cyclone IV E" ENA_REGISTER_MODE="none" IMPLEMENT_IN_LES="OFF" NUMBER_OF_CLOCKS=2 USE_GLITCH_FREE_SWITCH_OVER_IMPLEMENTATION="ON" WIDTH_CLKSELECT=1 clkselect inclk outclk CARRY_CHAIN="MANUAL" CARRY_CHAIN_LENGTH=48
