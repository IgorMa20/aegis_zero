`timescale 1ns / 1ps
// ============================================================
// mphf_lookup.v – AEGIS-ZERO Warstwa 2
// Oblicza LHD = (g1[h1(src_ip)] + g2[h2(src_ip)]) % 10000
// Potok 2-cyklowy:
//   cykl 1: odczyt g1_ram[addr1] i g2_ram[addr2]
//   cykl 2: obliczenie sumy i redukcja modulo
// Funkcje h1/h2 muszą być identyczne z gen_mphf.py
// ============================================================
module mphf_lookup (
    input  wire        clk,
    input  wire        valid_in,
    input  wire [31:0] dst_ip,

    output reg         valid_out,
    output reg  [13:0] idx,        // LHD – indeks do BRAM reguł [0..9999]
    output reg  [31:0] dst_ip_out  // src_ip przekazane dalej w potoku
);
    // ── Parametry ─────────────────────────────────────────────
    parameter G_SIZE = 16384;  // rozmiar tablic g1, g2 (2^14)

    // ── Tablice pomocnicze MPHF ────────────────────────────────
    // Przechowujemy jako 32-bit (format $readmemh), obcinamy do 14 bit przy użyciu
    reg [31:0] g1_ram [0:G_SIZE-1];
    reg [31:0] g2_ram [0:G_SIZE-1];
    initial begin
        $readmemh("g1.hex", g1_ram);
        $readmemh("g2.hex", g2_ram);
    end

    // ── Funkcje mieszające (kombinacyjne) ─────────────────────
    // h1(ip) = ((ip ^ 0xA5A5A5A5) >> 7) ^ ((ip ^ 0xA5A5A5A5) << 13)  [13:0]
    wire [31:0] x1     = dst_ip ^ 32'hA5A5A5A5;
    wire [31:0] h1_val = (x1 >> 7) ^ (x1 << 13);
    wire [13:0] addr1  = h1_val[13:0];   // & G_MASK

    // h2(ip) = (({ip[15:0],ip[31:16]} ^ 0x3C3C3C3C) >> 11) ^
    //          (({ip[15:0],ip[31:16]} ^ 0x3C3C3C3C) << 5)   [13:0]
    wire [31:0] rot    = {dst_ip[15:0], dst_ip[31:16]};
    wire [31:0] x2     = rot ^ 32'h3C3C3C3C;
    wire [31:0] h2_val = (x2 >> 11) ^ (x2 << 5);
    wire [13:0] addr2  = h2_val[13:0];   // & G_MASK

    // ── Rejestry potokowe etap 1 ───────────────────────────────
    reg        valid_r1;
    reg [31:0] dst_ip_r1;
    reg [13:0] g1_data;
    reg [13:0] g2_data;

    // Cykl 1: odczyt z tablic g1/g2
    always @(posedge clk) begin
        g1_data   <= g1_ram[addr1][13:0];  // obetnij do 14 bitów
        g2_data   <= g2_ram[addr2][13:0];
        valid_r1  <= valid_in;
        dst_ip_r1 <= dst_ip;
    end

    // ── Obliczenie indeksu etap 2 ──────────────────────────────
    // sum = g1_data + g2_data; max = 9999+9999 = 19998 < 20000
    // -> jedno warunkowe odejmowanie wystarczy zamiast prawdziwego modulo
    wire [14:0] sum = {1'b0, g1_data} + {1'b0, g2_data};

    // Cykl 2: wynik
    always @(posedge clk) begin
        idx        <= (sum >= 15'd10000) ? sum[13:0] - 14'd10000 : sum[13:0];
        valid_out  <= valid_r1;
        dst_ip_out <= dst_ip_r1;
    end

endmodule
